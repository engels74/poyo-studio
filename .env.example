# Poyo credentials are read only by the local SvelteKit server.
POYO_API_KEY=

# The production launcher accepts loopback addresses only (127.0.0.1 or ::1).
HOST=127.0.0.1
PORT=3000

# Optional server-side application-data root. Leave empty to use <repository>/data.
# PLS_APP_DATA_DIR=

# Optional bounded JSONL log rotation settings.
PLS_LOG_SEPARATE_ERRORS=true
PLS_LOG_MAX_BYTES=5242880
PLS_LOG_MAX_AGE_MS=86400000
PLS_LOG_RETENTION_AGE_MS=1209600000
PLS_LOG_MAX_FILES=10
